APP_ENV=production
LOG_LEVEL=INFO
POSTGRES_URL=postgresql+asyncpg://shopify_roxor:shopify_roxor@postgres:5432/shopify_roxor
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2026-04
SHOPIFY_LOCATION_ID=gid://shopify/Location/123456789
SHOPIFY_WEBHOOK_SECRET=replace-me
SFTP_HOST=sftp.roxor.example
SFTP_PORT=22
SFTP_USERNAME=roxor
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=
SFTP_OUTBOUND_ORDERS_PATH=/outbound/orders/
SFTP_INBOUND_DELIVERY_PATH=/inbound/delivery/
SFTP_INBOUND_STOCK_PATH=/inbound/stock/
SFTP_INBOUND_INVOICE_PATH=/inbound/invoice/
SFTP_ARCHIVE_PATH=/archive/
SFTP_ERROR_PATH=/error/
SFTP_POLL_INTERVAL_SECONDS=30
RETRY_WORKER_INTERVAL_SECONDS=15
LOCAL_WORK_DIR=/tmp/shopify-roxor
